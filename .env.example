# ──────────────────────────────────────────────────────────────────────────────
# Root .env template for Docker Compose deployment
# ──────────────────────────────────────────────────────────────────────────────

# Dokploy Integration Settings
# URL pointing to your Dokploy instances API endpoint
DOKPLOY_URL=https://dokploy.yourdomain.com/api
# API Token generated from Dokploy settings
DOKPLOY_TOKEN=your_dokploy_token_here

# Frontend Build & Runtime Settings
# Public-facing URL of the Backend service. Next.js needs this at build-time.
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
